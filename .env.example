# -------- Immich connection --------
IMMICH_URL=http://your-immich-host:2283
IMMICH_API_KEY=REPLACE_ME

# -------- Postgres (inside your Immich docker network) --------
# If you run this compose file in the SAME folder/network as Immich, PGHOST is usually immich_postgres
PGHOST=immich_postgres
PGPORT=5432
PGDATABASE=immich
PGUSER=postgres
PGPASSWORD=postgres

# -------- Captioner behavior --------
BATCH_SIZE=50
SLEEP_SECONDS=0.2
IDLE_SLEEP_SECONDS=60
MAX_CAPTION_CHARS=12000
USER_AGENT=immich-captioner/2.3
DRY_RUN=0
CAPTION_VIDEOS=0

# Keyframe sampling: sparse coverage of the video's "setup", dense fixed-interval
# coverage of the last VIDEO_TAIL_SECONDS (where the action tends to concentrate).
VIDEO_TAIL_SECONDS=240
VIDEO_TAIL_INTERVAL_SECONDS=15
VIDEO_HEAD_FRAME_COUNT=4
MAX_VIDEO_FRAMES=24

ENABLE_TAGS=0

# If 1, detailed captions are instructed to describe sexual content directly
# and explicitly (no euphemisms) instead of writing a sanitized caption.
EXPLICIT_CAPTIONS=1


# API-only mode (DEFAULT: true)
# If true: Uses paginated Immich API calls to find uncaptioned assets (safer, no direct DB access, but slower for large libraries).
# If false: Uses direct Postgres query for efficiency (requires valid PG* credentials; riskier if Immich schema changes).
USE_API_ONLY=true


# -------- Florence (OCR pre-pass only) --------
FLORENCE_MODEL=microsoft/Florence-2-large

# -------- JoyCaption (detailed/explicit captions; images + video frames) --------
JOYCAPTION_MODEL=fancyfeast/llama-joycaption-beta-one-hf-llava

# -------- Container base image --------
CUDA_BASE_IMAGE=nvidia/cuda:12.6.3-cudnn-runtime-ubuntu24.04

# -------- Legacy identity envs (optional; captioner.py still reads them) --------
IDENTITY_ALBUM_MAP=Lydia=Lydia;Me=Me
IDENTITY_NOUN_HINTS=Lydia=woman,girl,person;Me=man,guy,person
IDENTITY_ENSURE_MODE=prefix
